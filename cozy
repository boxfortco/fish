</div>

<script>
  // Smart platform detection
  function isMobile() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  }
  function isQuest() {
    return /OculusBrowser|Quest/i.test(navigator.userAgent);
  }

  function getPlatformHint() {
    if (isQuest()) return 'You\'re on Meta Quest — tap below to install VRChat';
    if (isMobile()) return 'Available on Meta Quest & PC via Steam';
    return 'Available on PC via Steam & Meta Quest headsets';
  }

  document.getElementById('platform-hint').textContent = getPlatformHint();

  // Direct route if clear platform
  function openModal() {
    if (isQuest()) {
      window.open('https://www.oculus.com/experiences/quest/1856672347794301/', '_blank');
    } else {
      document.getElementById('modal').classList.add('active');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('active');
    document.body.style.overflow = '';
  }

  function closeModalOutside(e) {
    if (e.target === document.getElementById('modal')) closeModal();
  }

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  document.querySelectorAll('.feature-block').forEach(el => observer.observe(el));

  // Audio toggle (stub — no autoplay without user interaction)
  let audioOn = false;
  document.querySelector('.audio-toggle').addEventListener('click', function() {
    audioOn = !audioOn;
    this.textContent = audioOn ? '🔊' : '🔉';
    this.title = audioOn ? 'Mute ambient sounds' : 'Play ambient sounds';
  });
</script>
